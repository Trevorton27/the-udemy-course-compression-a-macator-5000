{
  "name": "udemy-transcript-extractor",
  "version": "1.0.0",
  "description": "CLI tool to extract visible Udemy course transcripts to Markdown and JSON.",
  "type": "module",
  "scripts": {
    "scrape": "tsx src/index.ts",
    "optimize": "tsx src/optimize.ts",
    "scan": "tsx src/scan.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "server": "tsx src/server/index.ts",
    "ui": "vite",
    "dev:ui": "concurrently \"tsx src/server/index.ts\" \"vite\"",
    "build:ui": "vite build",
    "test": "node --import tsx/esm --test src/**/*.test.ts"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "playwright": "^1.48.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^9.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vite": "^8.0.16"
  },
  "engines": {
    "node": ">=20"
  }
}
